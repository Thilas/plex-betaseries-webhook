    "axios": "1.18.1",
    "config": "4.4.2",
    "domurl": "2.3.4",
    "express": "5.2.1",
    "inversify": "8.1.1",
    "js-yaml": "5.2.0",
    "md5": "2.3.0",
    "multer": "2.2.0",
    "reflect-metadata": "0.2.2",
    "serve-favicon": "2.5.1",
    "winston": "3.19.0"
